# Copy this file to .env and fill in your real values.
# .env is gitignored and will never be committed or built into dist.

# OAuth2 client ID (Chrome Extension type) — from Google Cloud Console → APIs & Services → Credentials
VITE_OAUTH_CLIENT_ID=your-oauth-client-id-here

# Dev-only extension key — CWS Developer Dashboard → Package → View public key (one long line, no PEM headers)
# Leave empty or omit when building for CWS submission — the key field is excluded from the output automatically
VITE_EXTENSION_KEY=your-extension-public-key-here

# Groq API key — get one free at https://console.groq.com/keys
VITE_GROQ_DEFAULT_API_KEY=your_groq_api_key_here

# Langfuse observability (optional — only needed if LANGFUSE_ENABLED = true in config.ts)
VITE_LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
VITE_LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
